# ──────────────────────────────────────────────────────────────────────────────
# NeuroGrid Flutter App — .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials (NEVER commit these) ─────────────────────────────
env.json
.env
.env.*
google-services.json
GoogleService-Info.plist
key.properties
*.jks
*.keystore
*.p12
*.pem
*.pfx

# ── Flutter/Dart/Pub related ────────────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/web/

# ── Build outputs ────────────────────────────────────────────────────────────
/android/app/debug/
/android/app/profile/
/android/app/release/
android/app/.cxx/
*.apk
*.aab
*.ipa

# ── Symbolication & obfuscation ──────────────────────────────────────────────
app.*.symbols
app.*.map.json

# ── IntelliJ / Android Studio ───────────────────────────────────────────────
*.iml
*.ipr
*.iws
.idea/

# ── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# ── Miscellaneous ────────────────────────────────────────────────────────────
*.class
*.log
*.pyc
*.swp
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
