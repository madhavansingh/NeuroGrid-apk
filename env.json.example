{
  "_comments": {
    "SUPABASE_URL":       "→ https://supabase.com/dashboard → your project → Settings → API → Project URL",
    "SUPABASE_ANON_KEY":  "→ Same page as above → anon / public key",
    "OPENAI_API_KEY":     "→ https://platform.openai.com/api-keys  (prefix: sk-…)",
    "GEMINI_API_KEY":     "→ https://aistudio.google.com/app/apikey  (free tier available)",
    "ANTHROPIC_API_KEY":  "→ https://console.anthropic.com/settings/keys  (prefix: sk-ant-…)",
    "PERPLEXITY_API_KEY": "→ https://www.perplexity.ai/settings/api  (prefix: pplx-…)",
    "GOOGLE_WEB_CLIENT_ID": "→ https://console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs",
    "AWS_LAMBDA_CHAT_COMPLETION_URL": "→ Optional. Lambda proxy URL. If empty the app calls Gemini/OpenAI directly.",
    "OPENWEATHER_API_KEY": "→ https://home.openweathermap.org/api_keys  (free 1 000 calls/day)",
    "GOOGLE_MAPS_API_KEY": "→ https://console.cloud.google.com → Credentials → Maps API key",
    "TOMTOM_API_KEY":     "→ https://developer.tomtom.com/user/me/apps  (free 2 500 calls/day)",
    "API_BASE_URL":       "→ IP of the machine running FastAPI. Find with: ifconfig | grep 'inet '",
    "RETELL_API_KEY":     "→ https://app.retellai.com/dashboard → Settings → API Keys (prefix: key_…). Used SERVER-SIDE only — backend calls POST /v2/create-web-call to get the access_token. Never put this key in the Flutter app."
  },

